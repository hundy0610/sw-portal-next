# ────────────────────────────────────────────────────────────
# Notion API 설정 (필수)
# ────────────────────────────────────────────────────────────
# 1. https://www.notion.so/my-integrations 에서 Integration 생성
# 2. 아래 토큰 값을 복사해서 붙여넣기
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# Notion 데이터베이스 ID (필수)
# 각 DB 페이지 URL에서 추출: notion.so/workspace/{DATABASE_ID}?v=...
# ────────────────────────────────────────────────────────────

# SW DB (화이트리스트/블랙리스트)
NOTION_DB_SWDB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 구독 관리 DB
NOTION_DB_SUBSCRIPTIONS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 라이선스 트래커 DB
NOTION_DB_LICENSES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 티켓/요청 DB
NOTION_DB_TICKETS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# 노션 원본 링크 (관리자 페이지에서 "노션 보기" 버튼 연결용)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_NOTION_TRACKER_URL=https://www.notion.so/your-license-tracker-page
NEXT_PUBLIC_NOTION_SUBSCRIBE_URL=https://www.notion.so/your-subscription-page

# ────────────────────────────────────────────────────────────
# 앱 설정 (선택)
# ────────────────────────────────────────────────────────────
# 관리자 비밀번호 (간단한 보호용 - 실제 인증은 별도 구현 권장)
ADMIN_PASSWORD=admin1234

# 캐시 TTL (초 단위, 기본값 60)
CACHE_TTL=60
