# ────────────────────────────────────────────────────────────
# 맥북 중앙 Postgres 접속 (4.0verMACBOOK)
#
# 자체 호스팅 Supabase(Docker)를 Tailscale Funnel(HTTPS)로 노출한 주소에 접속한다.
# 아래 두 값이 있으면 KV(공지/계정/설정/매뉴얼 등 — lib/kv-store.ts)가 전부 이 Postgres
# 를 사용한다. DATA_SOURCE=postgres 이면 HW 읽기도 이 Postgres 를 1차 소스로 사용한다.
#
# SUPABASE_KEY 는 service_role 키다(서버 전용, 브라우저로 절대 노출 금지). API 라우트·
# 크론·미들웨어 등 서버 코드에서만 사용된다. 공개 Funnel 경로이므로 이 키 보관이 곧 보안이다.
# ────────────────────────────────────────────────────────────
# DATA_SOURCE=postgres
# SUPABASE_URL=https://<기기명>.<tailnet>.ts.net      # Tailscale Funnel 공개 주소
# SUPABASE_KEY=<Supabase service_role key>            # 서버 전용. 읽기/쓰기(RLS 우회)
# SWP_DB_SECRET=<커스텀 공유 시크릿>                   # 선택(보완책). 설정 시 x-swp-secret 헤더로 전송

# 참고: KV 저장소가 맥북 Postgres 로 이전되어 Upstash(UPSTASH_REDIS_REST_URL/TOKEN,
# KV_REST_API_URL/TOKEN)는 더 이상 런타임에서 사용하지 않는다. 기존 데이터 이관은
# scripts/seed-kv.ts 참고(이관 시에만 Upstash 자격증명 사용).

# ────────────────────────────────────────────────────────────
# Notion API 설정 (필수)
# ────────────────────────────────────────────────────────────
# 1. https://www.notion.so/my-integrations 에서 Integration 생성
# 2. 아래 토큰 값을 복사해서 붙여넣기
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# Notion 데이터베이스 ID (필수)
# 각 DB 페이지 URL에서 추출: notion.so/workspace/{DATABASE_ID}?v=...
# ────────────────────────────────────────────────────────────

# SW DB (화이트리스트/블랙리스트)
NOTION_DB_SWDB=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 구독 관리 DB
NOTION_DB_SUBSCRIPTIONS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 라이선스 트래커 DB
NOTION_DB_LICENSES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 티켓/요청 DB
NOTION_DB_TICKETS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 헬프데스크 DB (문의 접수 현황)
NOTION_DB_HELPDESK=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 수리 접수 DB
NOTION_DB_REPAIR_TICKETS=29a67f4bfdac800aad9bc46ec605caa4

# 작업 트래커 DB (개인 작업 트래커)
NOTION_DB_WORK_TRACKER=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# 노션 원본 링크 (관리자 페이지에서 "노션 보기" 버튼 연결용)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_NOTION_TRACKER_URL=https://www.notion.so/your-license-tracker-page
NEXT_PUBLIC_NOTION_SUBSCRIBE_URL=https://www.notion.so/your-subscription-page

# ────────────────────────────────────────────────────────────
# 앱 설정 (선택)
# ────────────────────────────────────────────────────────────
# 관리자 비밀번호 (간단한 보호용 - 실제 인증은 별도 구현 권장)
ADMIN_PASSWORD=admin1234

# 관리자 세션 쿠키 서명용 비밀키 (필수) - 생성: openssl rand -hex 32
# 미설정 시 모든 관리자 로그인/세션 검증이 거부됩니다.
SESSION_SECRET=

# ENV 슈퍼어드민 로그인 정보 (필수) - 미설정 시 이 계정으로 로그인 불가
# SUPER_ADMIN_ID 미설정 시 기본값 "admin" 사용
SUPER_ADMIN_ID=
SUPER_ADMIN_PW=

# 계정 관리(ID/PW) 화면의 제3자 서비스 비밀번호 암호화 키 (필수) - 생성: openssl rand -base64 32
# 미설정 시 계정 관리 화면에서 비밀번호 저장/조회가 실패합니다. 유출/변경 시 기존 암호화된 값을 복호화할 수 없으니 안전하게 보관하세요.
CREDENTIALS_ENC_KEY=

# 캐시 TTL (초 단위, 기본값 60)
CACHE_TTL=60

# ────────────────────────────────────────────────────────────
# 이메일 발송 (Resend)
# https://resend.com 에서 API 키 발급 + 도메인 인증 필요
# ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 발신자 이메일 (Resend에서 인증된 도메인 주소)
# 예: noreply@your-company.com
RESEND_FROM_EMAIL=noreply@your-company.com

# 앱 URL (피드백 링크 생성용)
NEXT_PUBLIC_APP_URL=https://assetify-desk-main.vercel.app

# 만료 알림 수신자 (쉼표 구분)
ALERT_EMAILS=admin@your-company.com

# ────────────────────────────────────────────────────────────
# 포털 관리모드 설정
# 접속 URL 예시: https://your-domain.com/manage?key=MANAGE_SECRET_KEY
# ────────────────────────────────────────────────────────────

# URL에 포함되는 시크릿 키 (이 URL을 아는 사람만 관리페이지 진입 시도 가능)
MANAGE_SECRET_KEY=your-secret-url-key-here

# 관리모드 비밀번호 (2차 인증)
MANAGE_PASSWORD=your-manage-password-here

# ────────────────────────────────────────────────────────────
# Notion 포털 콘텐츠 DB (나중에 생성 후 추가)
# ────────────────────────────────────────────────────────────

# 공지사항 DB
# NOTION_DB_NOTICES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 교육과정 DB
# NOTION_DB_COURSES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 자료실 DB
# NOTION_DB_RESOURCES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# /request (assetify-desk 통합) 전용 환경변수
# NOTION_TOKEN은 위의 공통 토큰을 그대로 사용함
# ────────────────────────────────────────────────────────────
ASSETS_DATA_SOURCE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INQUIRY_TICKETS_DATA_SOURCE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REPAIR_TICKETS_DATA_SOURCE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MEETING_RENTAL_DATA_SOURCE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# 자산실사 프로그램 배포 페이지 (/asset-audit)
# Vercel 프로젝트 > Storage 탭에서 Blob 스토어 연결 시 자동 주입됨
# ────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ────────────────────────────────────────────────────────────
# PC 신규 등록 (자산 실사 방식, /api/pc-register 수집 엔드포인트)
# 온라인 자산 실사(/api/pc-scan)와 별도의 전용 Notion DB를 사용
# ────────────────────────────────────────────────────────────

# 신규 등록 전용 수집 DB (기존 실사 DB와 동일한 속성으로 새로 생성)
NOTION_DB_PC_REGISTER=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 수집 프로그램이 요청 헤더 x-scan-key로 보내는 인증키
PC_REGISTER_INGEST_KEY=
